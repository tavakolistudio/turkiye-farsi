# ─────────────────────────────────────────────────────────────
#  Turkey Farsi (ترکیه فارسی) — environment variables
#  Copy to .env and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Database (Prisma). Local dev uses the embedded Postgres from `npm run db:start`.
# In production, point these at your Supabase Postgres connection strings.
#   - DATABASE_URL: pooled connection (used by the app at runtime, serverless-safe)
#   - DIRECT_URL:   direct connection (used by `prisma migrate deploy`)
#
# Supabase production example (get these from: Project → Settings → Database →
# Connection string). Do NOT put real values here — set them in .env.local / Vercel.
#   DATABASE_URL = Transaction pooler (port 6543) + `?pgbouncer=true&connection_limit=1`
#   DIRECT_URL   = Direct/Session connection (port 5432), used only by migrations
# Example shape (placeholders — replace [REF], [REGION], [PASSWORD]):
#   DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
#   DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:54329/turkiye_farsi"
DIRECT_URL="postgresql://postgres:postgres@localhost:54329/turkiye_farsi"

# Local embedded-postgres overrides (optional)
PG_DEV_PORT=54329
PG_DEV_USER=postgres
PG_DEV_PASSWORD=postgres
PG_DEV_DB=turkiye_farsi

# Public site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ترکیه فارسی"

# Supabase (Auth + Storage). Leave blank for local-only development.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET="media"

# Email (Resend) — newsletter & transactional
RESEND_API_KEY=
EMAIL_FROM="ترکیه فارسی <noreply@example.com>"

# Observability & analytics
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_ID=

# Security secrets (generate with: openssl rand -hex 32)
CRON_SECRET=
WEBHOOK_SECRET=

# Initial Super Admin (read by the seed script — never hardcode real values)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME="مدیر ارشد"
